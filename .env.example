# Walour root — aggregate env reference. Copy relevant vars to:
#   apps/worker/.env             (server-side: HELIUS, ANTHROPIC, SUPABASE service key, etc.)
#   apps/extension/.env.development OR .env.production  (VITE_* build-time vars)
#   apps/web/.env.local          (NEXT_PUBLIC_* + server-side service key)
# Everything below is documented separately in each app's own .env.example.

# ---- Worker (apps/worker/.env) ----
HELIUS_API_KEY=
TRITON_KEY=
RPC_FAST_API_KEY=
GOPLUS_API_KEY=
ANTHROPIC_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
TWITTER_BEARER_TOKEN=
WALOUR_PROGRAM_ID=
PROGRAM_AUTHORITY_KEYPAIR=
JUPITER_API_KEY=
NODE_ENV=development
PORT=3001
WALOUR_CRON_SECRET=
WALOUR_ORACLE_CLUSTER=devnet
EXTENSION_ID=

# ---- Extension (apps/extension/.env.development | .env.production) ----
# Wave 1B: extension now uses mode-aware envs. .env.development points at
# http://localhost:3001; .env.production points at https://walour.vercel.app.
# See apps/extension/.env.example for the canonical single-mode template.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=http://localhost:3001
