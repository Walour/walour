# Walour extension — Wave 1B introduced mode-aware env files.
# Vite picks the right file based on --mode passed in package.json scripts:
#   npm run dev    → .env.development  (VITE_API_BASE=http://localhost:3001)
#   npm run build  → .env.production   (VITE_API_BASE=https://walour.vercel.app)
#
# To bootstrap a fresh checkout, copy this file to BOTH:
#   cp .env.example .env.development
#   cp .env.example .env.production
# Then set VITE_API_BASE in each appropriately and fill in the Supabase values.
# All three files (.env.development, .env.production, .env) are gitignored.

# Worker API base URL (consumed by content.ts, background.ts, popup.ts).
# .env.development : http://localhost:3001
# .env.production  : https://walour.vercel.app
VITE_API_BASE=http://localhost:3001

# Supabase project URL — baked into background.ts at build time via vite.config.ts.
VITE_SUPABASE_URL=

# Supabase anon key — baked into background.ts at build time via vite.config.ts.
VITE_SUPABASE_ANON_KEY=
