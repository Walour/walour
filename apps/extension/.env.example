# Copy to .env and fill in your values

# Worker API base URL (used by content.ts for /api/simulate calls)
VITE_API_BASE=http://localhost:3001

# Supabase project URL (baked into background.ts at build time via vite.config.ts)
VITE_SUPABASE_URL=

# Supabase anon key (baked into background.ts at build time via vite.config.ts)
VITE_SUPABASE_ANON_KEY=
