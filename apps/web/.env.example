# Copy to .env.local and fill in your values

# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (server-only — never expose to the browser)
SUPABASE_SERVICE_KEY=

# Walour worker API base URL (used by /demo page for live scan calls)
NEXT_PUBLIC_WALOUR_API_BASE=
