# Walour worker — copy to apps/worker/.env and fill in your values.
# All real secrets are gitignored; this file documents required var names only.

# Supabase project — service role key has full DB access; never expose to client.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Solana RPC providers (Helius primary, Triton/RPC Fast fallbacks).
HELIUS_API_KEY=
TRITON_KEY=
RPC_FAST_API_KEY=

# Anthropic — Claude Haiku for streaming tx decoder.
ANTHROPIC_API_KEY=

# Upstash Redis (REST) — cache-first layer for SDK calls.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# On-chain oracle — deployed program ID + authority keypair (JSON array of bytes).
WALOUR_PROGRAM_ID=
PROGRAM_AUTHORITY_KEYPAIR=

# GoPlus Security — token + domain threat intel (free tier).
GOPLUS_API_KEY=

# Jupiter Developer Platform — token metadata + risk intel (free tier, 60 RPM).
JUPITER_API_KEY=

# Runtime
NODE_ENV=development
PORT=3001

# Wave 3C — cron-class auth shared secret (32 random hex bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# On Vercel: also set CRON_SECRET to the SAME value (Vercel auto-injects it as
# Authorization: Bearer <CRON_SECRET> on scheduled cron invocations).
WALOUR_CRON_SECRET=

# Wave 3C — oracle PDA reads target this cluster (devnet | mainnet).
# Market-data RPC (Helius) stays mainnet regardless.
WALOUR_ORACLE_CLUSTER=devnet
