SUPABASE_URL=
SUPABASE_SERVICE_KEY=
HELIUS_API_KEY=
ANTHROPIC_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TWITTER_BEARER_TOKEN=
WALOUR_PROGRAM_ID=
PROGRAM_AUTHORITY_KEYPAIR=
NODE_ENV=development
RPC_FAST_API_KEY=

# GoPlus Security — token malicious check + phishing domain feed
# Free tier at https://docs.gopluslabs.io — create account at https://gopluslabs.io
# Used in: token-risk.ts (honeypot/blacklist), domain-check.ts (live phishing check), ingest worker (domain feed)
GOPLUS_API_KEY=

# Jupiter token metadata enrichment for sim row
# Free tier at https://portal.jup.ag — V1 token endpoint requires this header.
# Optional: if absent, sim still works but shows truncated mint addresses instead of symbols.
JUPITER_API_KEY=

# Walour Chrome extension ID — locks CORS to your specific extension (production only)
# Find it at chrome://extensions after loading the unpacked extension
EXTENSION_ID=
