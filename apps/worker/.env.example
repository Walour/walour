SUPABASE_URL=
SUPABASE_SERVICE_KEY=
HELIUS_API_KEY=
ANTHROPIC_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TWITTER_BEARER_TOKEN=
WALOUR_PROGRAM_ID=
PROGRAM_AUTHORITY_KEYPAIR=
NODE_ENV=development
RPC_FAST_API_KEY=

# GoPlus Security — token malicious check + phishing domain feed
# Free tier at https://docs.gopluslabs.io — create account at https://gopluslabs.io
# Used in: token-risk.ts (honeypot/blacklist), domain-check.ts (live phishing check), ingest worker (domain feed)
GOPLUS_API_KEY=

# Jupiter Developer Platform — token metadata + risk intelligence
# Free tier at https://portal.jup.ag (1 RPS, 60 RPM — sufficient at current scale)
# Used by:
#   apps/worker/src/simulate.ts       -> v1 token endpoint (symbol enrichment for sim rows)
#   packages/sdk/src/token-risk.ts    -> v2 search + price v3 (organic score, audit.isSus, liquidity)
# Optional: if absent, both Jupiter checks silently skip; rest of risk engine still runs.
JUPITER_API_KEY=

# Walour Chrome extension ID — locks CORS to your specific extension (production only)
# Find it at chrome://extensions after loading the unpacked extension
EXTENSION_ID=
