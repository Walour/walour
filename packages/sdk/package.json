{
  "name": "@walour/sdk",
  "version": "0.1.0",
  "description": "AI-powered real-time scam protection SDK for Solana — domain checks, token risk scoring, streaming Claude transaction explanations, and on-chain threat oracle integration.",
  "keywords": [
    "solana",
    "security",
    "scam-protection",
    "wallet",
    "drainer",
    "phishing",
    "anchor",
    "oracle",
    "defi",
    "anthropic",
    "claude"
  ],
  "homepage": "https://walour.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/Walour/Walour.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Walour/Walour/issues"
  },
  "author": "Sahir <sikandersahir@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @solana/web3.js --external @anthropic-ai/sdk --external @upstash/redis --external @cloak.dev/sdk",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external @solana/web3.js --external @anthropic-ai/sdk --external @upstash/redis --external @cloak.dev/sdk",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@solana/web3.js": "^1.98.0",
    "@upstash/redis": "^1.34.0"
  },
  "optionalDependencies": {
    "@cloak.dev/sdk": "^0.1.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@solana/web3.js$": "<rootDir>/../../node_modules/@solana/web3.js",
      "^@cloak.dev/sdk$": "<rootDir>/tests/__mocks__/@cloak.dev/sdk.js"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "resolveJsonModule": true
        }
      }
    }
  }
}
